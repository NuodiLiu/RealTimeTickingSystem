# Test Environment Configuration
# Used by the test suite

NODE_ENV=test
PORT=3001

# Test Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ticketing_test
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ticketing_test

# Test Session Configuration
SESSION_KEYS=test-session-key-1,test-session-key-2
JWT_SECRET=test-jwt-secret

# Mock Azure AD for testing
MOCK_AZURE_AD=true
AZURE_CLIENT_ID=test-client-id
AZURE_CLIENT_SECRET=test-client-secret
AZURE_TENANT_ID=test-tenant-id
AZURE_REDIRECT_URI=http://localhost:3001/auth/callback

# Test Features
ENABLE_DEV_ROUTES=true
LOG_LEVEL=error
MOCK_EMAIL_SERVICE=true

# Disable external services in tests
ENABLE_DEVICE_CLEANUP=false
