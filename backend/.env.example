# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ==============================================
# Database Configuration
# ==============================================
DATABASE_URL="postgresql://username:password@localhost:5432/ticketing_db"
DATABASE_NAME="ticketing_db"
DATABASE_USER="postgres"
DATABASE_PASSWORD="your_secure_password"
DATABASE_PORT="5432"

# ==============================================
# Server Configuration
# ==============================================
NODE_ENV="development"
PORT="3000"
FRONTEND_URL="http://localhost:3001"

# ==============================================
# Session Configuration
# ==============================================
# Generate secure random keys for session encryption
# Use multiple keys separated by commas for key rotation
SESSION_KEYS="your-secret-key-1,your-secret-key-2,your-secret-key-3"

# ==============================================
# Azure AD Authentication
# ==============================================
# Azure AD application registration details
AZURE_CLIENT_ID="your-azure-client-id"
AZURE_CLIENT_SECRET="your-azure-client-secret"
AZURE_TENANT_ID="your-azure-tenant-id"
AZURE_REDIRECT_URI="http://localhost:3000/auth/callback"

# Optional: Restrict to specific tenant (leave empty to allow any tenant)
# AZURE_ALLOWED_TENANTS="tenant-id-1,tenant-id-2"

# ==============================================
# JWT Configuration
# ==============================================
# Secret for signing JWT tokens (used for WebSocket authentication)
JWT_SECRET="your-jwt-secret-key"

# ==============================================
# Redis Configuration (Optional)
# ==============================================
# If using Redis for session storage or caching
# REDIS_URL="redis://localhost:6379"
# REDIS_PASSWORD="your_redis_password"

# ==============================================
# Email Configuration (Optional)
# ==============================================
# For sending notifications or alerts
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@domain.com"
# SMTP_PASSWORD="your-email-password"
# SMTP_FROM="your-email@domain.com"

# ==============================================
# Logging Configuration
# ==============================================
# Log level: error, warn, info, debug
LOG_LEVEL="info"

# ==============================================
# Security Configuration
# ==============================================
# CORS origins (comma-separated list)
CORS_ORIGINS="http://localhost:3001,https://yourdomain.com"

# Trust proxy (set to true if behind reverse proxy)
TRUST_PROXY="false"

# ==============================================
# Features Flags (Optional)
# ==============================================
# Enable/disable specific features
ENABLE_DEVICE_CLEANUP="true"
ENABLE_EXCEL_EXPORT="true"
ENABLE_FEEDBACK_SYSTEM="true"

# ==============================================
# External Services (Optional)
# ==============================================
# If integrating with external services
# ANALYTICS_API_KEY="your-analytics-key"
# MONITORING_API_KEY="your-monitoring-key"

# ==============================================
# Development/Testing Configuration
# ==============================================
# These settings are only used in development/test environments

# Enable development routes and features
ENABLE_DEV_ROUTES="true"

# Test database (for running tests)
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ticketing_test"

# Mock external services in development
MOCK_AZURE_AD="false"
MOCK_EMAIL_SERVICE="true"
