{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "dev": "dotenv -e .env -- ts-node-dev --respawn src/server.ts",
    "dev:functions": "dotenv -e .env -- func start",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "prepublish": "npm run build",
    "build:functions": "npm run build",
    "start": "node dist/src/server.js",
    "start:functions": "func start",
    "deploy": "npm run build:functions && func azure functionapp publish $AZURE_FUNCTIONAPP",
    "postinstall": "prisma generate",
    "test": "jest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
