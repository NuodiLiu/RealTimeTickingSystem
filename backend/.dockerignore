# Docker ignore file for backend
# Ignore node_modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore log files
logs/
*.log

# Ignore test coverage
coverage/

# Ignore build output
dist/
build/

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore git
.git/
.gitignore

# Ignore documentation
README.md
docs/
*.md

# Ignore database files
*.sqlite
*.sqlite3
*.db

# Ignore temporary files
tmp/
temp/
.tmp/

# Ignore docker files in docker build
Dockerfile*
docker-compose*.yml
.dockerignore

# Ignore prisma migrations (will be run in container)
prisma/migrations/

# Ignore test files
tests/
*.test.js
*.test.ts
*.spec.js
*.spec.ts
jest.config.js

# Ignore scripts that aren't needed in production
scripts/check-db-state.js
scripts/cleanup-devices-simple.js
scripts/clear-db.js
