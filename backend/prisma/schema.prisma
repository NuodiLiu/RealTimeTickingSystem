// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CaseStatus {
  QUEUED
  IN_PROGRESS
  RESOLVED
}

model Staff {
  id       String          @id @default(cuid())
  employeeNo  String   @unique 
  name     String
  email    String          @unique
  password String // for MVP; replace with SSO later
  cases    StudentCase[]
  feedback Feedback[]
  tokens   FeedbackToken[]
  idp         IdpAccount?
  role       StaffRole    @default(STAFF)   
}

enum StaffRole { STAFF ADMIN }

model Invite {
  id           String   @id @default(cuid())
  tokenHash    String                                
  createdById  String
  createdBy    Staff    @relation("StaffCreatedInvites", fields: [createdById], references: [id])
  expiresAt    DateTime
  usedAt       DateTime?
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
}

model Session {
  id           String   @id @default(cuid())
  staffId      String
  staff        Staff    @relation(fields: [staffId], references: [id])
  refreshHash  String                                
  ua           String?
  ip           String?
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime @default(now())
  expiresAt    DateTime                              
  revokedAt    DateTime?
}

model IdpAccount {
  id         String @id @default(cuid())
  staffId    String @unique
  staff      Staff  @relation(fields: [staffId], references: [id])
  provider   String // "azuread" | "saml" | ...
  subject    String // idp sub
}

model StudentCase {
  id          String     @id @default(cuid())
  studentName String
  category    String
  status      CaseStatus @default(QUEUED)
  staffId     String? // nullable until taken
  staff       Staff?     @relation(fields: [staffId], references: [id])
  createdAt   DateTime   @default(now())
  resolvedAt  DateTime?

  feedback Feedback[]
  tokens   FeedbackToken[]

  @@index([status])
  @@index([staffId])
  @@index([createdAt])
}

model Feedback {
  id        String   @id @default(cuid())
  caseId    String
  staffId   String
  rating    Int // 1..5
  comment   String?
  createdAt DateTime @default(now())

  case  StudentCase @relation(fields: [caseId], references: [id])
  staff Staff       @relation(fields: [staffId], references: [id])

  @@index([caseId])
  @@index([staffId])
}

model FeedbackToken {
  token     String   @id // cryptographically random, URL-safe
  shortCode String?  @unique
  caseId    String
  staffId   String
  expireAt  DateTime
  used      Boolean  @default(false)

  case  StudentCase @relation(fields: [caseId], references: [id])
  staff Staff       @relation(fields: [staffId], references: [id])

  @@index([expireAt, used])
}

model KioskDevice {
  id            String     @id @default(cuid())
  name          String     // e.g. "Front Desk iPad 1"
  secretHash    String     // Device pairing secret (store hash after one-time pairing/QR)
  status        String     @default("IDLE") // IDLE | BUSY | OFFLINE
  lastSeenAt    DateTime   @default(now())

  // Current lock (nullable; set when BUSY)
  currentLockId String?
  currentLock   KioskLock? @relation(fields: [currentLockId], references: [id])

  @@index([status])
  @@index([lastSeenAt])
}

model KioskLock {
  id            String       @id @default(cuid())
  deviceId      String
  device        KioskDevice  @relation(fields: [deviceId], references: [id])

  // Who initiated the lock
  staffId       String
  staff         Staff        @relation(fields: [staffId], references: [id])

  // Business context bound to this lock
  caseId        String
  case          StudentCase  @relation(fields: [caseId], references: [id])

  // Exactly one active lock per device at a time
  active        Boolean      @default(true)

  // Lock lease (heartbeat + expiry)
  leaseExpireAt DateTime

  createdAt     DateTime     @default(now())
  releasedAt    DateTime?

  @@index([deviceId, active])
  @@index([leaseExpireAt])
}
