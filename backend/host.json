{
  "version": "2.0",
  "languageWorkers": {
    "node": {
      "arguments": ["--max-old-space-size=2048"]
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[3.*, 4.0.0)"
  },
  "extensions": {
    "signalRService": {
      "connectionString": "AZURE_SIGNALR_CONNECTION_STRING"
    }
  },
  "logging": {
    "logLevel": {
      "default": "Information",
      "Function": "Information"
    }
  },
  "functionTimeout": "00:05:00",
  "healthMonitor": {
    "enabled": true
  }
}
